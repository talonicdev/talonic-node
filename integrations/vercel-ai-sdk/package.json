{
  "name": "@talonic/ai-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Talonic document-extraction tool for the Vercel AI SDK. Turn any document into schema-validated JSON inside your AI SDK agents.",
  "license": "MIT",
  "author": "Talonic GmbH <info@talonic.ai> (https://talonic.com)",
  "homepage": "https://talonic.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talonicdev/talonic-node.git",
    "directory": "integrations/vercel-ai-sdk"
  },
  "keywords": [
    "talonic",
    "ai-sdk",
    "vercel-ai-sdk",
    "tool",
    "agent",
    "document-extraction",
    "structured-data"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "rm -rf dist coverage"
  },
  "peerDependencies": {
    "@talonic/node": ">=0.1.0",
    "ai": ">=4",
    "zod": ">=3.23"
  },
  "devDependencies": {
    "@talonic/node": "file:../..",
    "@types/node": "^22.10.0",
    "ai": "^6.0.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4",
    "zod": "^4.0.0"
  }
}
